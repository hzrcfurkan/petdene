generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
}

model Account {
    id                String  @id @default(uuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(uuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id                 String         @id @default(uuid())
    name               String?
    email              String         @unique
    emailVerified      DateTime?
    password           String?  // Optional for OAuth users
    role               String         @default("CUSTOMER") // SUPER_ADMIN, ADMIN, STAFF, or CUSTOMER
    phone              String?
    image              String?
    currencyPreference String?        @default("TRY") // USD or TRY - prices stored in TRY, converted for display
    deletedAt          DateTime?      // Soft delete
    createdAt          DateTime       @default(now())
    updatedAt          DateTime       @updatedAt
    accounts      Account[]
    sessions      Session[]
    pets          Pet[]
    appointments  Appointment[]
    prescriptions Prescription[]
    visits        Visit[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// -----------------------------
// PET CARE MODELS
// -----------------------------

model Pet {
    id            String    @id @default(uuid())
    patientNumber String    @unique // Auto-generated: PAT-000001
    ownerId       String
    name          String
    species       String // Dog, Cat, Bird, etc.
    breed         String?
    gender        String? // Male/Female
    age           Int?
    dateOfBirth   DateTime?
    weight        Float?
    color         String?
    image         String?
    notes         String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    vaccinations  Vaccination[]
    medicalLogs   MedicalRecord[]
    prescriptions Prescription[]
    appointments  Appointment[]
    visits        Visit[]
}

model PetService {
    id          String   @id @default(uuid())
    title       String
    type        String // grooming, vet-checkup, bath, boarding, training
    description String?
    duration    Int? // in minutes
    price       Float
    image       String?
    active      Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    appointments Appointment[]
    visitServices VisitService[]
}

// Visit = central transaction unit when patient comes to clinic
model Visit {
    id             String    @id @default(uuid())
    protocolNumber Int       @unique // Sequential: 1, 2, 3...
    petId          String
    appointmentId  String?   // Optional link to scheduled appointment
    staffId        String?
    visitDate      DateTime
    status         String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, CANCELLED
    totalAmount    Float     @default(0)
    paidAmount     Float     @default(0)
    notes          String?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    pet         Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
    appointment Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
    staff       User?         @relation(fields: [staffId], references: [id])
    services    VisitService[]
    medicalRecord MedicalRecord?
    payments    VisitPayment[]
    invoice     Invoice?
    stockUsages VisitStockUsage[]
}

// Services added to a Visit (with quantity and unit price)
model VisitService {
    id         String   @id @default(uuid())
    visitId    String
    serviceId String
    quantity  Int      @default(1)
    unitPrice Float
    total     Float    // quantity * unitPrice
    notes     String?
    createdAt DateTime @default(now())

    visit   Visit      @relation(fields: [visitId], references: [id], onDelete: Cascade)
    service PetService @relation(fields: [serviceId], references: [id], onDelete: Restrict)
}

// Multiple payments per Visit (partial/full)
model VisitPayment {
    id                    String    @id @default(uuid())
    visitId               String
    method                String // cash, card, stripe
    amount                Float
    transactionId         String?
    stripePaymentIntentId  String?
    stripeClientSecret    String?
    status                String    @default("COMPLETED") // PENDING, COMPLETED, FAILED, CANCELLED
    paidAt                DateTime  @default(now())
    notes                 String?
    createdAt             DateTime  @default(now())

    visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

model Appointment {
    id        String   @id @default(uuid())
    petId     String
    serviceId String
    staffId   String? // Vet/Groomer assigned
    date      DateTime
    status    String   @default("PENDING")
    notes     String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    pet     Pet        @relation(fields: [petId], references: [id], onDelete: Cascade)
    service PetService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    staff   User?      @relation(fields: [staffId], references: [id])
    invoice Invoice?
    visits  Visit[]    // Visit created when patient actually arrives
}

model Vaccination {
    id             String    @id @default(uuid())
    petId          String
    vaccineName    String
    dateGiven      DateTime?
    nextDue        DateTime?
    notes          String?
    isPlanned      Boolean   @default(false)
    scheduledDate  DateTime?
    scheduledTime  String?
    stockItemId    String?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    pet       Pet        @relation(fields: [petId], references: [id], onDelete: Cascade)
    stockItem StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
}

model MedicalRecord {
    id                   String   @id @default(uuid())
    petId                String
    visitId              String?  @unique // Epicrisis linked to Visit
    title                String
    description          String?
    diagnosis            String?
    treatment            String?
    date                 DateTime @default(now())
    // Epicrisis fields (when linked to Visit)
    complaints           String?
    examinationNotes     String?
    treatmentsPerformed  String?
    recommendations      String?

    pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
    visit Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)
}

model Prescription {
    id           String   @id @default(uuid())
    petId        String
    issuedById   String
    medicineName String
    dosage       String?
    instructions String?
    dateIssued   DateTime @default(now())

    pet      Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
    issuedBy User @relation(fields: [issuedById], references: [id])
}

model Invoice {
    id            String   @id @default(uuid())
    appointmentId String?  @unique // Optional: invoice from scheduled appointment
    visitId       String?  @unique // Optional: invoice from visit (protocol)
    amount        Float
    status        String   @default("UNPAID") // UNPAID, PAID, CANCELLED, PARTIAL
    notes         String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
    visit       Visit?      @relation(fields: [visitId], references: [id], onDelete: Cascade)
    payment     Payment?
}

model Payment {
    id                    String    @id @default(uuid())
    invoiceId             String    @unique
    method                String // card, cash, stripe
    transactionId         String?
    stripePaymentIntentId String? // Stripe Payment Intent ID
    stripeClientSecret    String? // Stripe client secret for frontend
    amount                Float
    paidAt                DateTime?
    status                String    @default("PENDING") // PENDING, COMPLETED, FAILED, CANCELLED
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============ STOK YÖNETİMİ ============

model StockItem {
    id           String   @id @default(uuid())
    name         String                          // İlaç/malzeme adı
    category     String   @default("İlaç")      // İlaç, Malzeme, Ürün, Diğer
    unit         String   @default("Adet")       // Adet, ml, mg, kutu, şişe...
    quantity     Float    @default(0)            // Mevcut stok miktarı
    minQuantity  Float    @default(5)            // Min. stok uyarı eşiği
    price        Float    @default(0)            // Birim satış fiyatı (TRY)
    costPrice    Float    @default(0)            // Maliyet fiyatı
    description  String?
    barcode      String?
    isActive     Boolean  @default(true)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    usages       VisitStockUsage[]
    vaccinations Vaccination[]
}

model VisitStockUsage {
    id          String   @id @default(uuid())
    visitId     String
    stockItemId String
    quantity    Float                           // Kullanılan miktar
    unitPrice   Float                           // Uygulanan birim fiyat
    total       Float                           // quantity * unitPrice
    notes       String?
    createdAt   DateTime @default(now())

    visit     Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)
    stockItem StockItem @relation(fields: [stockItemId], references: [id])
}
